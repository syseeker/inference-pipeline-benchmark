# Copy to `.env` and fill in. `.env` itself is gitignored.

# NVIDIA NIM (OpenAI-compatible)
NIM_API_KEY=
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
# NIM cloud does NOT expose Qwen2.5-VL or Qwen3-VL today (verified 2026-05).
# The only multimodal Qwen NIM in the catalogue is qwen/qwen3.5-397b-a17b
# (400B MoE — large, slow; useful for pipeline-correctness smoke only).
# For real Qwen3-VL benchmarks, self-host per QUICKSTART Mode B and point
# NIM_BASE_URL at http://localhost:8001/v1 with NIM_MODEL set to the
# local container's served id.
# To list everything your key can reach:
#   bash scripts/list_nim_models.sh
NIM_MODEL=qwen/qwen3.5-397b-a17b

# Local vLLM / SGLang servers (if used)
VLLM_BASE_URL=http://localhost:8000/v1
SGLANG_BASE_URL=http://localhost:30000/v1

# Triton
TRITON_GRPC_URL=localhost:8001
